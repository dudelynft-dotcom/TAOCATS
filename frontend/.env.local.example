# Fill these after running: npx hardhat run scripts/deploy.ts --network subtensor

# Contract addresses (Bittensor EVM, Chain ID 964)
NEXT_PUBLIC_NFT_ADDRESS=0x
NEXT_PUBLIC_MARKETPLACE_ADDRESS=0x
NEXT_PUBLIC_BEAR_TOKEN_ADDRESS=0x

# WalletConnect project ID — get free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# Set to "true" to point at testnet (Chain ID 945)
NEXT_PUBLIC_USE_TESTNET=false
