# Bittensor EVM — Subtensor Network
# Mainnet Chain ID: 964  |  RPC: https://lite.chain.opentensor.ai
# Testnet Chain ID: 945  |  RPC: https://test.chain.opentensor.ai
# Docs: https://docs.learnbittensor.org/evm-tutorials

DEPLOYER_PRIVATE_KEY=your_metamask_private_key_here

# Network RPCs
TAO_RPC_URL=https://lite.chain.opentensor.ai
TAO_TESTNET_RPC_URL=https://test.chain.opentensor.ai

# Addresses to fill after deploying liquidity pool / multisig
LIQUIDITY_RECEIVER=0x_your_liquidity_pool_or_multisig_address

# IPFS — upload output/ to Pinata, paste CID here
UNREVEALED_URI=ipfs://YOUR_CID/unrevealed.json

# Optional: block explorer API key
TAO_EXPLORER_API_KEY=no-key-needed
